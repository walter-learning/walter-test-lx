# Base URL of the mock API (lambda infra/test_technique or local proxy)
MOCK_API_BASE_URL=https://your-mock-api.example.com

# Optional: sent as header x-api-key; same value as Lambda env X_API_KEY when the mock enforces it.
# Use MOCK_X_API_KEY or X_API_KEY (either is enough).
MOCK_X_API_KEY=
# X_API_KEY=
